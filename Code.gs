function doGet(e) {
if (e && e.parameter && e.parameter.dashboard !== undefined) return Pipeline_serveDashboard().setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL); // Deal Calculator page — opens with ?calc=1
  if (e && e.parameter && e.parameter.loantracker !== undefined) return Pipeline_serveLoanTracker(); // Loan Tracker page — opens with ?loantracker
  if (e && e.parameter && e.parameter.calc !== undefined) {
    return HtmlService.createHtmlOutputFromFile('DealCalc')
      .setTitle('ASAP Deal Calculator') 
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
      .addMetaTag('viewport', 'width=device-width, initial-scale=1');
  }

  // Creative Options structuring page — opens with ?creative=1 (served as its own window from the calculator)
  if (e && e.parameter && e.parameter.creative !== undefined) {
    return HtmlService.createHtmlOutputFromFile('CreativeOptions')
      .setTitle('ASAP Creative Options')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
      .addMetaTag('viewport', 'width=device-width, initial-scale=1');
  }

  var p = (e && e.parameter) ? e.parameter : {};

  // Upload mode: borrower returning via the follow-up link to add remaining documents
  var uploadToken = p.upload ? String(p.upload) : '';
  if (uploadToken) {
    var up = loadUpload(uploadToken);
    var info = up ? { dealRef: up.dealId, name: up.name || '',
      outstanding: (up.outstanding || []).map(function (f) { return { field: f, label: prettyLabel(f) }; }) } : null;
    var tu = HtmlService.createTemplateFromFile('Index');
    tu.draftToken = ''; tu.draftJson = 'null'; tu.draftStep = 1; tu.savedDocsJson = '{}';
    tu.uploadToken = up ? uploadToken : '';
    tu.uploadInfoJson = JSON.stringify(info);
    return tu.evaluate().setTitle('ASAP Funding - Upload documents')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1');
  }

  var token = p.resume ? String(p.resume) : '';
  var draft = token ? loadDraft(token) : null;
  var t = HtmlService.createTemplateFromFile('Index');
  t.draftToken = (draft ? token : '');
  t.draftJson  = JSON.stringify(draft && draft.data ? draft.data : null);
  t.draftStep  = (draft && draft.step) ? draft.step : 1;
  t.savedDocsJson = JSON.stringify(draft && draft.savedDocs ? draft.savedDocs : {});
  t.uploadToken = ''; t.uploadInfoJson = 'null';
  return t.evaluate()
    .setTitle('ASAP Funding - Loan Application')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

// ---------- SAVE & RESUME ----------
function saveDraft(token, data, step, files) {
  var props = PropertiesService.getScriptProperties();
  var isNew = !token;
  if (isNew) token = Utilities.getUuid().replace(/-/g, '').slice(0, 16);
  var rec = loadDraft(token) || {};
  rec.data = data || {};
  rec.step = step || 1;
  rec.savedAt = new Date().toISOString();
  rec.savedDocs = rec.savedDocs || {};
  if (files && files.length) {
    var folder = getDraftFolder(token);
    files.forEach(function (f) {
      if (!f || !f.dataBase64 || !f.field) return;
      var old = rec.savedDocs[f.field];
      if (old && old.fileId) { try { DriveApp.getFileById(old.fileId).setTrashed(true); } catch (e) {} }
      var blob = Utilities.newBlob(Utilities.base64Decode(f.dataBase64), f.mimeType || 'application/octet-stream', f.name || (f.field + '.dat'));
      var file = folder.createFile(blob);
      rec.savedDocs[f.field] = { name: f.name || file.getName(), url: file.getUrl(), fileId: file.getId() };
    });
  }
  props.setProperty('DRAFT_' + token, JSON.stringify(rec));
  var emailed = false;
  if (isNew && data && data.email) emailed = sendResumeLink(data.email, getWebAppUrl() + '?resume=' + token, data);
  return { ok: true, token: token, emailed: emailed, savedDocs: docsForClient(rec.savedDocs) };
}
function docsForClient(sd) {
  var out = {}; Object.keys(sd || {}).forEach(function (k) { out[k] = { name: sd[k].name, url: sd[k].url }; }); return out;
}
function getDraftsRoot() {
  var parent = getParentFolder(), it = parent.getFoldersByName('_Drafts');
  return it.hasNext() ? it.next() : parent.createFolder('_Drafts');
}
function getDraftFolder(token) {
  var root = getDraftsRoot(), it = root.getFoldersByName(token);
  return it.hasNext() ? it.next() : root.createFolder(token);
}
function loadDraft(token) {
  var raw = PropertiesService.getScriptProperties().getProperty('DRAFT_' + token);
  if (!raw) return null;
  try { return JSON.parse(raw); } catch (e) { return null; }
}
function deleteDraft(token) {
  if (!token) return;
  PropertiesService.getScriptProperties().deleteProperty('DRAFT_' + token);
  try { var root = getDraftsRoot(), it = root.getFoldersByName(token); if (it.hasNext()) it.next().setTrashed(true); } catch (e) {}
}
function getWebAppUrl() { try { return ScriptApp.getService().getUrl(); } catch (e) { return ''; } }

/* ===== Creative Options layout persistence (server-side, keyed by deal address) =====
 * Same fix as CalcNotes: the browser's localStorage is cleared/partitioned inside Google's
 * sandboxed iframe, so the multi-leg layout is stored on a self-created CreativeLayouts tab,
 * keyed by a normalized deal address, and restored from there on reopen. */
function _cly_sheet_() {
  var ss = ss_();
  var sh = ss.getSheetByName('CreativeLayouts');
  if (!sh) { sh = ss.insertSheet('CreativeLayouts'); sh.getRange(1, 1, 1, 3).setValues([['DealKey', 'LayoutJSON', 'Updated']]).setFontWeight('bold'); }
  return sh;
}
function _cly_norm_(s) { return String(s || '').toLowerCase().replace(/[^0-9a-z]+/g, ''); }
function pipeline_saveCreativeLayout(dealKey, json) {
  try {
    var key = _cly_norm_(dealKey);
    if (!key) return { ok: false, error: 'Missing deal key.' };
    var sh = _cly_sheet_();
    var vals = sh.getDataRange().getValues();
    var rowIdx = -1;
    for (var r = 1; r < vals.length; r++) { if (_cly_norm_(vals[r][0]) === key) { rowIdx = r + 1; break; } }
    var s = String(json == null ? '' : json); if (s.length > 45000) s = s.slice(0, 45000);
    if (rowIdx < 0) { rowIdx = sh.getLastRow() + 1; sh.getRange(rowIdx, 1).setValue(dealKey); }
    sh.getRange(rowIdx, 2).setValue(s);
    sh.getRange(rowIdx, 3).setValue(new Date());
    return { ok: true };
  } catch (err) { return { ok: false, error: String(err) }; }
}
function pipeline_getCreativeLayout(dealKey) {
  try {
    var key = _cly_norm_(dealKey);
    if (!key) return '';
    var sh = _cly_sheet_();
    var vals = sh.getDataRange().getValues();
    for (var r = 1; r < vals.length; r++) { if (_cly_norm_(vals[r][0]) === key) return String(vals[r][1] || ''); }
    return '';
  } catch (err) { return ''; }
}

