  if (!raw) return null;
  try { return JSON.parse(raw); } catch (e) { return null; }
}

function uploadMissingDocs(token, files) {
  try {
    var rec = loadUpload(token);
    if (!rec) return { ok: false, error: 'This upload link is no longer active.' };
    var folder = DriveApp.getFolderById(rec.folderId);
    var added = [], addedFields = {};
    (files || []).forEach(function (f) {
      if (!f || !f.dataBase64) return;
      var blob = Utilities.newBlob(Utilities.base64Decode(f.dataBase64), f.mimeType || 'application/octet-stream', f.name || (f.field + '.dat'));
      folder.createFile(blob);
      added.push(prettyLabel(f.field)); addedFields[f.field] = true;
    });
    var remaining = (rec.outstanding || []).filter(function (fl) { return !addedFields[fl]; });
    rec.outstanding = remaining;
    var props = PropertiesService.getScriptProperties();
    if (remaining.length) props.setProperty('UPLOAD_' + token, JSON.stringify(rec));
    else props.deleteProperty('UPLOAD_' + token);
    if (added.length) {
      MailApp.sendEmail(NOTIFY_EMAIL, 'Documents uploaded - ' + rec.dealId,
        ['The borrower uploaded documents for ' + rec.dealId + ':', ''].concat(added.map(function (x) { return ' - ' + x; }))
          .concat(['', (remaining.length ? 'Still pending: ' + remaining.map(prettyLabel).join(', ') : 'All requested documents are now in.'),
            '', 'Folder: ' + folder.getUrl()]).join('\n'), { cc: NOTIFY_CC });
    }
    return { ok: true, added: added.length, remaining: remaining.map(function (fl) { return { field: fl, label: prettyLabel(fl) }; }) };
  } catch (err) {
    return { ok: false, error: String(err) };
  }
}

