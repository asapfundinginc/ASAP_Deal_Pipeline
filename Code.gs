// ---------- SUBMIT ----------
function submitApplication(data, files, token, deferDocs, outstanding) {
  try {
    var dealId = makeDealId(data);
    var folder = getParentFolder().createFolder(dealId);
    var savedLinks = [], newFields = {};
    (files || []).forEach(function (f) {
      if (!f || !f.dataBase64) return;
      newFields[f.field] = true;
      var blob = Utilities.newBlob(Utilities.base64Decode(f.dataBase64), f.mimeType || 'application/octet-stream', f.name || (f.field + '.dat'));
      savedLinks.push(prettyLabel(f.field) + ': ' + folder.createFile(blob).getUrl());
    });
    if (token) {
      var rec = loadDraft(token);
      if (rec && rec.savedDocs) {
        Object.keys(rec.savedDocs).forEach(function (field) {
          if (newFields[field]) return;
          var sd = rec.savedDocs[field];
          try { var ff = DriveApp.getFileById(sd.fileId); ff.moveTo(folder); savedLinks.push(prettyLabel(field) + ': ' + ff.getUrl()); } catch (e) {}
        });
      }
    }
    // anything still outstanding has not been uploaded or saved as a draft doc
    var pending = (deferDocs && outstanding && outstanding.length)
      ? outstanding.filter(function (fl) { return !newFields[fl]; }) : [];
    var snap = gradeDeal(data);
    var _pdid = '';
    if (token) { try { var _pr = loadDraft(token); if (_pr && _pr.pipelineDealId) _pdid = _pr.pipelineDealId; } catch (e) {} }
    if (_pdid) {
      try { Pipeline_writeBackFromApp(_pdid, data, snap); } catch (e) {}
      try { pipeline_linkDriveFolderIfEmpty(_pdid, folder.getUrl()); } catch (e2) {}
    } else {
      // walk-up (no invite): auto-create a Pipeline deal so EVERY application lands on the board
      try { pipeline_createDealFromApp_(dealId, data, snap, folder.getUrl()); } catch (e3) {}
    }
    logToSheet(dealId, data, folder.getUrl(), snap);
    sendNotification(dealId, data, folder.getUrl(), savedLinks, pending, snap);
    deleteDraft(token);

    var pendingCount = 0;
    if (pending.length && data.email) {
      var uploadToken = Utilities.getUuid().replace(/-/g, '').slice(0, 16);
      PropertiesService.getScriptProperties().setProperty('UPLOAD_' + uploadToken, JSON.stringify({
        folderId: folder.getId(), dealId: dealId, name: data.firstName || '', email: data.email, outstanding: pending
      }));
      sendDocsFollowup(data.email, getWebAppUrl() + '?upload=' + uploadToken, data, pending);
      pendingCount = pending.length;
    }
    return { ok: true, dealId: dealId, folderUrl: folder.getUrl(), pendingCount: pendingCount };
  } catch (err) {
    return { ok: false, error: String(err) };
  }
}

function loadUpload(token) {
