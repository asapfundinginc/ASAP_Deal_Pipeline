    idDoc:'Photo ID (driver\'s license or passport)', entityDocs:'Your LLC paperwork (Articles + Operating Agreement)',
    proofOfFunds:'Proof of funds for your down payment (bank or asset statement)', proofOfInsurance:'Proof of property insurance',
    purchaseAgreement:'Signed purchase agreement', earnestMoneyProof:'Proof of your earnest money deposit (escrow receipt)',
    payoffStatement:'Your current mortgage / payoff statement', appraisal:'Recent appraisal or valuation (if you have one)',
    scopeOfWork:'Scope of work / rehab budget', constructionBudget:'Construction budget',
    budgetSOW:'Your construction budget & scope of work', experienceTracker:'A list of your past projects and the properties you own',
    drawSchedule:'Draw schedule (how construction funds are released in stages)', constructionTimeline:'Construction timeline',
    plansPermits:'Plans, permits, or survey', contractorDocs:'Your contractor\'s license & agreement',
    borrowerExperience:'Project track record', leaseRentRoll:'Leases / rent roll (list of tenants and what they pay)',
    incomeVerification:'Income verification (W-2s or pay stubs)', zoningPermits:'Zoning certificate or land-use permit',
    operatingStatement:'Operating statements (last 12 months of income & expenses)',
    additionalCollateralDoc:'Additional collateral' };
  return map[field] || field;
}
