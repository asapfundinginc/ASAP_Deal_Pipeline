function makeDealId(d) {
  var name = ((d.firstName || '') + ' ' + (d.lastName || '')).trim() || 'Borrower';
  var street = String(d.propertyAddress || '').split(',')[0];           // street portion of the address
  var base = (street ? (name + ' - ' + street) : name).replace(/[\/\\]/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 120) || 'Loan App';
  var parent = getParentFolder(), folderName = base, n = 2;             // avoid an identical-name collision
  while (parent.getFoldersByName(folderName).hasNext()) { folderName = base + ' (' + n + ')'; n++; }
  return folderName;
}
function getParentFolder() {
  var it = DriveApp.getFoldersByName(PARENT_FOLDER_NAME);
  return it.hasNext() ? it.next() : DriveApp.createFolder(PARENT_FOLDER_NAME);
}

