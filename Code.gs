/* Walk-up applications: create a Pipeline deal card, then reuse the same
   write-back that invited applications use so all fields populate identically. */
function pipeline_createDealFromApp_(appDealId, data, snap, folderUrl) {
  try {
    var sh = ss_().getSheetByName(ASAP_CFG.DEALS_TAB);
    if (!sh) return '';
    try { pipeline_ensureColumns_(); } catch (e) {}
    var H = sh.getRange(1, 1, 1, sh.getLastColumn()).getValues()[0];
    var row = []; for (var i = 0; i < H.length; i++) row.push('');
    function set(n, v) { var ci = H.indexOf(n); if (ci >= 0) row[ci] = v; }
    var id = 'app_' + String(appDealId || Utilities.getUuid().slice(0, 8));
    set('DealID', id);
    set('BorrowerName', (String(data.firstName || '') + ' ' + String(data.lastName || '')).trim());
    set('BorrowerEmail', String(data.email || ''));
    set('DateAdded', new Date());
    sh.appendRow(row);
    try { Pipeline_writeBackFromApp(id, data, snap); } catch (e) {}
    try { pipeline_linkDriveFolderIfEmpty(id, folderUrl); } catch (e) {}
    try { PL_cacheBust_(); } catch (e) {}
    return id;
  } catch (err) { return ''; }
}