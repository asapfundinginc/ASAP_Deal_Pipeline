function getLogSheet() {
  var props = PropertiesService.getScriptProperties(), id = props.getProperty('LOG_SHEET_ID'), ss = null;
  if (id) { try { ss = SpreadsheetApp.openById(id); } catch (e) { ss = null; } }
  if (!ss) {
    ss = SpreadsheetApp.create(SHEET_NAME);
    props.setProperty('LOG_SHEET_ID', ss.getId());
    ss.getSheets()[0].appendRow(MAIN.map(function (m) { return m[1]; }));
  }
  var sheet = ss.getSheets()[0];
  var lastCol = sheet.getLastColumn();
  if (lastCol > 0 && lastCol < MAIN.length) {
    sheet.getRange(1, lastCol + 1, 1, MAIN.length - lastCol)
      .setValues([MAIN.slice(lastCol).map(function (m) { return m[1]; })]);
  }
  return sheet;
}

function logToSheet(dealId, d, folderUrl, snap) {
  var ctx = {}; for (var k in d) ctx[k] = d[k];
  ctx.dealId = dealId; ctx.submitted = new Date(); ctx.folderUrl = folderUrl;
  if (snap) { ctx.grade = snap.grade; ctx.ltvPct = snap.ltvDisp; ctx.ltcPct = snap.ltcDisp; ctx.ltarvPct = snap.ltarvDisp; ctx.dscrEst = snap.dscrDisp; ctx.tier = snap.tierDisp; ctx.maxLoan = snap.approvedDisp; ctx.fit = snap.fitDisp; }
  var mainKeys = {}; MAIN.forEach(function (m) { mainKeys[m[0]] = true; });
  var extra = [];
  Object.keys(d).forEach(function (k) { if (!mainKeys[k] && d[k]) extra.push(k + ': ' + d[k]); });
  ctx.details = extra.join(' | ');
  getLogSheet().appendRow(MAIN.map(function (m) { return ctx[m[0]] != null ? ctx[m[0]] : ''; }));
}

function gradeDeal(d){
  d=d||{};
  function num(v){ if(v==null)return NaN; var n=parseFloat(String(v).replace(/[^0-9.\-]/g,'')); return isNaN(n)?NaN:n; }
  function pct(x){ return Math.round(x*100)+'%'; }
  function r2(x){ return Math.round(x*100)/100; }
  function money(x){ return '$'+Math.round(x).toLocaleString('en-US'); }
  var p=d.loanPurpose||'', occ=d.occupancy||'', pt=d.propertyType||'';
  var loan=num(d.loanAmount), asis=num(d.marketValue), price=num(d.purchasePrice), down=num(d.downPayment),
      rehab=num(d.rehabCost), arv=num(d.arv), ccost=num(d.constructionCost), ascomp=num(d.asCompleteValue),
      rent=num(d.monthlyRent), reserves=num(d.liquidReserves),
      taxesM=num(d.taxesMonthly), insM=num(d.insuranceMonthly), hoaM=num(d.hoaMonthly);

  // tier + fico
  var et=(d.experienceTier||''); var tier=(et.indexOf('Pro')>-1||et.indexOf('10+')>-1)?'Pro':((et.indexOf('Plus')>-1||et.indexOf('3-9')>-1||et.indexOf('3\u20139')>-1)?'Plus':'Self-Starter');
  var cb=(d.creditBand||''); var fm=cb.match(/(\d{3})/); var fico=(cb.indexOf('Below')>-1||cb.indexOf('<')>-1)?600:(fm?parseInt(fm[1]):NaN);
  function ficoAdjRehab(f){ if(!isFinite(f))return 0; if(f>=750)return -0.0025; if(f>=700)return 0; return 0.005; }
  function ficoAdjDSCR(f){ if(!isFinite(f))return 0; if(f>=760)return -0.0025; if(f>=720)return 0; if(f>=680)return 0.0025; if(f>=660)return 0.0075; if(f>=640)return 0.015; return 99; }

  var ratios=[], score=0, pos=[], flag=[];
  var sizing={tier:'', product:'', rate:'', points:'', approved:NaN, binding:'', fit:null, requested:loan};

  function ratio(n,disp){ ratios.push({name:n,disp:disp}); }

  var rehabType=(p==='Fix & Flip'||p==='Ground-Up Construction');
  var incomplete=(p==='Refinance' && (d.refiKind||'').indexOf('Incomplete')>-1);
  var isCashout=(p==='Cash-Out Refinance');
  var isDSCR=(p==='Rental / DSCR');

  var ltarv=NaN, ltc=NaN, ltv=NaN, dscr=NaN, approved=NaN, binding='', rate=NaN, pts=NaN, prod='';

  if(p==='Fix & Flip' || p==='Ground-Up Construction'){
    var cat;
    if(p==='Ground-Up Construction') cat='GroundUp';
    else { var sv=(d.cosmeticVsStructural||''); cat=(sv.indexOf('Heavy')>-1||sv.indexOf('Major')>-1)?'Heavy':'Light'; }
    var box=REHAB[tier][cat];
    var val=(p==='Ground-Up Construction')?ascomp:arv;
    var land=(p==='Ground-Up Construction')?(((d.constrMode||'').indexOf('buying')>-1&&isFinite(price))?price:0):price;
    var cost=(isFinite(land)?land:0)+(p==='Ground-Up Construction'?(isFinite(ccost)?ccost:0):(isFinite(rehab)?rehab:0));
    if(isFinite(loan)&&isFinite(val)&&val>0){ ltarv=loan/val; ratio(p==='Ground-Up Construction'?'Loan-to-complete':'LTARV', pct(ltarv)); }
    if(isFinite(loan)&&cost>0){ ltc=loan/cost; ratio('LTC', pct(ltc)); }
    var capA=isFinite(val)?box.ltarv*val:Infinity, capC=cost>0?box.ltc*cost:Infinity;
    approved=Math.min(capA,capC); binding=(capA<=capC)?(p==='Ground-Up Construction'?'as-complete value':'ARV'):'cost';
    rate=box.rate+ficoAdjRehab(fico); pts=box.pts; prod=tier+' tier \u00b7 '+(cat==='GroundUp'?'Ground-up':cat+' rehab');
  } else if(incomplete){
    var box2=REHAB[tier]['Heavy'];
    if(isFinite(loan)&&isFinite(ascomp)&&ascomp>0){ ltarv=loan/ascomp; ratio('Loan-to-complete', pct(ltarv)); approved=box2.ltarv*ascomp; binding='as-complete value'; }
    rate=box2.rate+ficoAdjRehab(fico); pts=box2.pts; prod=tier+' tier \u00b7 finish/rescue';
  } else if(isDSCR){
    // exact-ish PITIA DSCR
    if(isFinite(rent)&&rent>0&&isFinite(loan)&&loan>0){
      var io=loan*GUIDE.dscrRate/12;
      var pitia=io+(isFinite(taxesM)?taxesM:0)+(isFinite(insM)?insM:0)+(isFinite(hoaM)?hoaM:0);
      dscr=rent/pitia; ratio('DSCR', r2(dscr)+'x');
    }
    var isPurchase=(d.rentalAcq==='Buying'||(!isCashout&&p!=='Refinance'));
    var chosen=null;
    for(var i=0;i<DSCRT.length;i++){ var t=DSCRT[i]; if((!isFinite(dscr)||dscr>=t.floor) && (!isFinite(fico)||fico>=t.fico)){ chosen=t; break; } }
    var baseVal=(isFinite(asis)&&asis>0)?asis:price;
    var cashout=(isCashout||(d.rentalAcq==='Refinancing'));
    if(chosen){
      var lvcap=cashout?chosen.co:chosen.pur;
      if(isFinite(loan)&&isFinite(baseVal)&&baseVal>0){ ltv=loan/baseVal; ratio('LTV', pct(ltv)); }
      approved=isFinite(baseVal)?lvcap*baseVal:NaN; binding='LTV ('+pct(lvcap)+(cashout?' cash-out':' purchase')+')';
      rate=chosen.rate+(cashout?0.0025:0)+ficoAdjDSCR(fico); prod=chosen.name; sizing.product=chosen.name;
    } else { prod='No eligible DSCR tier'; flag.push('No DSCR tier fits (needs 720+ FICO for No-Ratio, or stronger DSCR)'); score+=4; }
  } else {
    // plain purchase / refi / cashout / bridge / land
    var baseV=(isFinite(asis)&&asis>0)?asis:price;
    if(isFinite(loan)&&isFinite(baseV)&&baseV>0){ ltv=loan/baseV; ratio('As-is LTV', pct(ltv)); }
    var cap = p==='Land'?GUIDE.ltvLandMax : isCashout?GUIDE.ltvCashoutMax : (p==='Refinance')?GUIDE.ltvRefiMax : (p==='Bridge')?GUIDE.ltvBridgeMax : GUIDE.ltvPurMax;
    approved=isFinite(baseV)?cap*baseV:NaN; binding='LTV ('+pct(cap)+')'; prod=(p||'Loan');
  }

  // down payment ratio (display)
  if(isFinite(down)&&isFinite(price)&&price>0&&p!=='Ground-Up Construction'){ ratio('Down payment', pct(down/price)); }

  // ----- FIT (authoritative) -----
  var fit=null;
  if(isFinite(approved)&&isFinite(loan)&&loan>0){
    if(loan<=approved*1.005){ fit=true; pos.push('Requested '+money(loan)+' is within the '+money(approved)+' max ('+binding+'-bound)'); }
    else { fit=false; var over=loan/approved;
      if(over>1.10){ score+=8; flag.push('Requested '+money(loan)+' is well over the '+money(approved)+' max ('+binding+')'); }
      else { score+=5; flag.push('Requested '+money(loan)+' exceeds the '+money(approved)+' max ('+binding+')'); } }
  } else { flag.push('Not enough numbers to size the loan'); }

  // DSCR tier quality
  if(isDSCR && isFinite(dscr)){ if(prod.indexOf('No-Ratio')>-1){score+=2;flag.push('No-Ratio DSCR tier (weak cash flow)');} else if(prod.indexOf('Reduced')>-1){score+=1;flag.push('Reduced-DSCR tier (+0.50% rate)');} else if(prod.indexOf('Standard')>-1){pos.push('Qualifies '+prod);} }

  // 100% financing
  var noCash=(d.hundredFinancing||'').indexOf('do not want to put any cash')>-1;
  if(noCash){ score+=2; flag.push('100% financing requested (no borrower cash in)'); }

  // credit / fico
  if(isFinite(fico)){ if(fico<640){ score+=3; flag.push('Credit below 640'); } else if(fico<660){ score+=1; flag.push('Credit 640-659 (limited programs)'); } }
  else { flag.push('Credit score not provided'); }
  if((d.pastDefaults||'')==='Yes'){ score+=2; flag.push('Past loan default / modification'); }
  if((d.bankruptcy7yr||'')==='Yes'){ score+=2; flag.push('Bankruptcy within 7 years'); }
  if((d.legalEncumbrances||'')==='Yes'){ score+=3; flag.push('Pending lawsuits / liens / judgments'); }
  if((d.otherLenders||'')==='Yes'){ score+=1; flag.push('Shopping multiple lenders'); }
  if(isFinite(reserves)&&isFinite(loan)&&loan>0&&reserves<loan*0.02){ score+=1; flag.push('Thin liquidity vs loan size'); }

  // structure / property
  if(occ==='Owner-occupied'){ score+=3; flag.push('Owner-occupied (most business-purpose lenders decline)'); }
  if(pt==='Commercial'){ score+=2; flag.push('Commercial property'); } else if(pt==='Mixed-use'){ score+=2; flag.push('Mixed-use property'); } else if(pt.indexOf('Multifamily')>-1){ score+=1; }
  if(incomplete){ score+=3; flag.push('Stalled / incomplete project'); }
  if(p==='Land'){ score+=2; flag.push('Land loan'); }

  var grade,label;
  if(score<=2){ grade='A'; label='Fits your standard funding box - most hard money lenders should fund'; }
  else if(score<=5){ grade='B'; label='Moderate - fundable, needs the right tier or lender'; }
  else if(score<=9){ grade='C'; label='Complex - over standard box or specialized lender needed'; }
  else { grade='D'; label='High-touch - well over box / significant hurdles'; }

  sizing.requestedDisp=isFinite(loan)?money(loan):''; sizing.tier=tier; sizing.product=prod; sizing.approved=approved; sizing.binding=binding; sizing.fit=fit;
  sizing.rate=isFinite(rate)?(Math.round(rate*10000)/100)+'%':''; sizing.points=isFinite(pts)?(r2(pts*100)+' pts'):'';
  sizing.approvedDisp=isFinite(approved)?money(approved):'';
  return { grade:grade, label:label, score:score, ratios:ratios, pos:pos, flag:flag, sizing:sizing,
    ltvDisp:isFinite(ltv)?pct(ltv):'', ltcDisp:isFinite(ltc)?pct(ltc):'', ltarvDisp:isFinite(ltarv)?pct(ltarv):'', dscrDisp:isFinite(dscr)?(r2(dscr)+'x'):'',
    tierDisp:tier, approvedDisp:isFinite(approved)?money(approved):'', fitDisp:(fit===null?'':(fit?'Fits':'Over max')) };
}

function sendNotification(dealId, d, folderUrl, savedLinks, outstanding, snap) {
  var subject = 'New Loan App - ' + (d.loanPurpose || 'Deal') + ' - ' + (d.firstName || '') + ' ' + (d.lastName || '') + ' [' + dealId + ']';
  function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  var H = [], P = [];
  function title(s) { H.push('<p style="margin:18px 0 4px;font-weight:bold;color:#0A5277;">' + esc(s) + '</p>'); P.push(''); P.push(s); }
  function rows(pairs) {
    var html = '';
    pairs.forEach(function (pr) { if (pr[1]) { html += esc(pr[0]) + ': ' + esc(pr[1]) + '<br>'; P.push(pr[0] + ': ' + pr[1]); } });
    H.push('<div style="margin:0 0 2px;">' + html + '</div>');
  }

  H.push('<p style="margin:0 0 12px;font-weight:bold;">New loan application submitted.</p>');
  H.push('<p style="margin:0 0 2px;"><strong>Deal ID:</strong> ' + esc(dealId) + '</p>');
  P.push('New loan application submitted.'); P.push(''); P.push('Deal ID: ' + dealId);

  if (snap) {
    var gc = { A:'#1a8f4c', B:'#0A5277', C:'#d98a00', D:'#c0392b' }[snap.grade] || '#0A5277';
    H.push('<div style="border:1px solid #e2e8f0;border-radius:10px;padding:12px 14px;margin:14px 0;background:#f7fafc;">');
    H.push('<p style="margin:0 0 6px;font-weight:bold;color:#0A5277;letter-spacing:.5px;">DEAL SNAPSHOT</p>');
    H.push('<p style="margin:0 0 8px;font-size:15px;"><span style="display:inline-block;background:' + gc + ';color:#fff;font-weight:bold;border-radius:6px;padding:2px 9px;margin-right:8px;">' + snap.grade + '</span><strong>' + esc(snap.label) + '</strong></p>');
    var sz = snap.sizing || {};
    if (sz.product) {
      var fitTxt = sz.fit === true ? '<span style="color:#1a8f4c;font-weight:bold;">fits</span>' : (sz.fit === false ? '<span style="color:#c0392b;font-weight:bold;">over max</span>' : '');
      H.push('<p style="margin:0 0 4px;">Profile: <strong>' + esc(sz.product) + '</strong>' + (sz.rate ? ' &middot; indicative rate ~' + esc(sz.rate) : '') + (sz.points ? ' / ' + esc(sz.points) : '') + '</p>');
      if (sz.approvedDisp) H.push('<p style="margin:0 0 8px;">Max loan: <strong>' + esc(sz.approvedDisp) + '</strong> (' + esc(sz.binding) + '-bound) &middot; requested ' + esc(sz.requestedDisp) + ' &mdash; ' + fitTxt + '</p>');
    }
    if (snap.ratios.length) H.push('<p style="margin:0 0 8px;">' + snap.ratios.map(function (x) { return esc(x.name) + ': <strong>' + esc(x.disp) + '</strong>'; }).join(' &nbsp;&middot;&nbsp; ') + '</p>');
    if (snap.pos.length) H.push('<p style="margin:0 0 2px;color:#1a8f4c;"><strong>Strengths:</strong> ' + esc(snap.pos.join('; ')) + '</p>');
    if (snap.flag.length) H.push('<p style="margin:0;color:#c0392b;"><strong>Watch-outs:</strong> ' + esc(snap.flag.join('; ')) + '</p>');
    H.push('</div>');
    P.push(''); P.push('DEAL SNAPSHOT'); P.push('Grade ' + snap.grade + ' - ' + snap.label);
    if (sz.product) { P.push('Profile: ' + sz.product + (sz.rate ? ' | rate ~' + sz.rate : '') + (sz.points ? ' ' + sz.points : '')); if (sz.approvedDisp) P.push('Max loan: ' + sz.approvedDisp + ' (' + sz.binding + ') | requested ' + sz.requestedDisp + ' - ' + (sz.fit === true ? 'fits' : (sz.fit === false ? 'OVER MAX' : ''))); }
    snap.ratios.forEach(function (x) { P.push('  ' + x.name + ': ' + x.disp); });
    if (snap.pos.length) P.push('Strengths: ' + snap.pos.join('; '));
    if (snap.flag.length) P.push('Watch-outs: ' + snap.flag.join('; '));
  }

  title('Borrower');
  rows([['Role', d.role], ['Name', ((d.firstName || '') + ' ' + (d.lastName || '')).trim()],
        ['Email', d.email], ['Phone', d.phone],
        ['Entity', (d.useEntity || '') + (d.entityName ? ' (' + d.entityName + ')' : '')]]);

  title('Loan & Property');
  rows([['Loan purpose', d.loanPurpose], ['Property', (d.propertyType || '') + ' - ' + (d.propertyAddress || '')],
        ['Commercial type', d.commercialType],
        ['Loan amount', d.loanAmount], ['Market value', d.marketValue], ['Top priority', d.loanPriority],
        ['Occupancy', d.occupancy], ['Condition', d.propertyCondition],
        ['Purchase price', d.purchasePrice], ['Down payment', d.downPayment],
        ['Payoff balance', d.payoffBalance], ['Current lender', d.currentLender], ['Cash-out', d.cashOutAmount],
        ['Rehab cost', d.rehabCost], ['ARV', d.arv], ['Value when complete', d.asCompleteValue], ['% complete', d.percentComplete],
        ['Monthly rent', d.monthlyRent], ['Construction cost', d.constructionCost], ['Spent so far', d.spentToDate], ['Cost to complete', d.costToComplete],
        ['Exit', d.exitStrategy], ['Exit detail', d.exitDetail],
        ['Partner', d.hasPartner ? (d.hasPartner + (d.partnerOwnership ? ' (' + d.partnerOwnership + ')' : '')) : '']]);

  title('Risk');
  rows([['Liquid reserves', d.liquidReserves],
        ['Past defaults', d.pastDefaults], ['Default/mod date', d.defaultDate],
        ['Bankruptcy 7yr', d.bankruptcy7yr], ['Bankruptcy date', d.bankruptcyDate],
        ['Lawsuits/liens', d.legalEncumbrances], ['Other lenders', d.otherLenders],
        ['Additional collateral', d.additionalCollateral],
        ['Collateral address', d.collateralAddress], ['Collateral type', d.collateralType], ['Collateral value', d.collateralValue],
        ['Collateral liens', d.collateralLiens], ['Collateral lien balance', d.collateralLienBalance],
        ['Notes', d.notes]]);

  title('Drive folder');
  H.push('<p style="margin:0 0 2px;"><a href="' + esc(folderUrl) + '">' + esc(folderUrl) + '</a></p>');
  P.push(folderUrl);

  if (savedLinks && savedLinks.length) {
    title('Uploaded documents');
    var ul = '';
    savedLinks.forEach(function (x) { ul += '&bull; ' + esc(x) + '<br>'; P.push(' - ' + x); });
    H.push('<div style="margin:0 0 2px;">' + ul + '</div>');
  }
  if (outstanding && outstanding.length) {
    title('Documents still needed');
    H.push('<p style="margin:0 0 2px;color:#667;">(borrower will upload via the emailed link)</p>');
    P.push('(borrower will upload via the emailed link)');
    var dl = '';
    outstanding.forEach(function (f) { dl += '&bull; ' + esc(prettyLabel(f)) + '<br>'; P.push(' - ' + prettyLabel(f)); });
    H.push('<div style="margin:0 0 2px;">' + dl + '</div>');
  }

  var html = '<div style="font-family:Arial,Helvetica,sans-serif;color:#1a2230;font-size:14px;line-height:1.55;max-width:680px;">' + H.join('') + '</div>';
  MailApp.sendEmail({ to: NOTIFY_EMAIL, cc: NOTIFY_CC, subject: subject, body: P.join('\n'), htmlBody: html });
}

function prettyLabel(field) {
